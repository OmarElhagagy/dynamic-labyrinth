# 1. استخدام نسخة بايثون خفيفة كقاعدة للعمل
FROM python:3.9-slim

# 2. تحديد المجلد داخل الحاوية (Container) اللي الشغل هينزل فيه
WORKDIR /app

# 3. نسخ ملف المكتبات أولاً لتسريع عملية البناء
COPY requirements.txt .

# 4. تثبيت المكتبات المطلوبة داخل الحاوية
RUN pip install --no-cache-dir -r requirements.txt

# 5. نسخ كل ملفات المشروع (الـ 10 ملفات والـ .pkl وقاعدة البيانات) لداخل الحاوية
COPY . .

# 6. الأمر اللي هيتنفذ لما الحاوية تشتغل (هنشغل المحرك الرئيسي)
CMD ["python", "main.py"]